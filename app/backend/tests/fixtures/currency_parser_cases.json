{
  "description": "Shared parity fixture for the user-typed currency amount parser. Consumed by pytest (parse_amount) and Vitest (frontend parseAmount). Every accepted entry must produce the same Decimal/string on both sides; every rejected entry must raise on both sides.",
  "accepted": [
    { "input": "0", "expected": "0" },
    { "input": "0.00", "expected": "0.00" },
    { "input": "100", "expected": "100" },
    { "input": "100.5", "expected": "100.5" },
    { "input": "100.50", "expected": "100.50" },
    { "input": "2500.00", "expected": "2500.00" },
    { "input": "$2500.00", "expected": "2500.00" },
    { "input": "$2,500.00", "expected": "2500.00" },
    { "input": "$1,234,567.89", "expected": "1234567.89" },
    { "input": "-100.00", "expected": "-100.00" },
    { "input": "  100.00  ", "expected": "100.00" },
    { "input": "$$100", "expected": "100" },
    { "input": "\t$1,000.00\n", "expected": "1000.00" },
    { "input": "1,000", "expected": "1000" },
    { "input": "0.01", "expected": "0.01" },
    { "input": "-0.01", "expected": "-0.01" }
  ],
  "rejected": [
    { "input": "" },
    { "input": "   " },
    { "input": "$" },
    { "input": "not-a-number" },
    { "input": "abc" },
    { "input": "1.2.3" },
    { "input": "1 000.00" },
    { "input": "-$100.00" }
  ]
}
